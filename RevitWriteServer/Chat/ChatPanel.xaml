<UserControl x:Class="RevitWriteServer.Chat.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RevitWriteServer.Chat"
             Background="#F0F2F5"
             FontFamily="Segoe UI">

  <UserControl.Resources>

    <!-- Shared button style -->
    <Style x:Key="BtnStyle" TargetType="Button">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Message bubble DataTemplate -->
    <DataTemplate x:Key="MsgTemplate" DataType="{x:Type local:ChatMessage}">
      <Grid Margin="8,3">
        <Border x:Name="Bdr" MaxWidth="270" Padding="11,8" CornerRadius="12"
                Background="White" HorizontalAlignment="Left">
          <Border.Effect>
            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.09" Color="Black"/>
          </Border.Effect>
          <TextBlock x:Name="Txt" Text="{Binding DisplayText}"
                     TextWrapping="Wrap" FontSize="13" LineHeight="20" Foreground="#1A1A1A"/>
        </Border>
      </Grid>
      <DataTemplate.Triggers>
        <DataTrigger Binding="{Binding IsUser}" Value="True">
          <Setter TargetName="Bdr" Property="Background"         Value="#0696D7"/>
          <Setter TargetName="Bdr" Property="HorizontalAlignment" Value="Right"/>
          <Setter TargetName="Txt" Property="Foreground"          Value="White"/>
        </DataTrigger>
      </DataTemplate.Triggers>
    </DataTemplate>

  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- header        -->
      <RowDefinition Height="*"/>     <!-- chat scroll   -->
      <RowDefinition Height="Auto"/>  <!-- status strip  -->
      <RowDefinition Height="Auto"/>  <!-- input row     -->
    </Grid.RowDefinitions>

    <!-- ── Header ── -->
    <Border Background="#0696D7" Padding="12,10">
      <Grid>
        <StackPanel VerticalAlignment="Center">
          <TextBlock x:Name="TitleText"
                     Text="BIM Assistant"
                     Foreground="White" FontWeight="SemiBold" FontSize="14"/>
          <TextBlock x:Name="MetaText"
                     Text="Waiting for pattern…"
                     Foreground="#AADCF5" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button x:Name="BtnExecute" Content="▶ Execute"
                  Style="{StaticResource BtnStyle}"
                  Background="#27AE60" Foreground="White"
                  Padding="10,6" FontSize="12" FontWeight="Medium"
                  Click="BtnExecute_Click"/>
          <Button x:Name="BtnDismiss" Content="✕ Dismiss"
                  Style="{StaticResource BtnStyle}"
                  Background="#44FFFFFF" Foreground="White"
                  Padding="8,6" FontSize="12"
                  Margin="6,0,0,0" Click="BtnDismiss_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Chat messages ── -->
    <ScrollViewer Grid.Row="1" x:Name="Scroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl x:Name="MsgList"
                    ItemTemplate="{StaticResource MsgTemplate}"
                    Padding="0,6,0,6"/>
    </ScrollViewer>

    <!-- ── Status strip ── -->
    <Border Grid.Row="2" x:Name="StatusBar"
            Padding="12,7" Visibility="Collapsed">
      <TextBlock x:Name="StatusText"
                 FontSize="12" TextWrapping="Wrap" FontWeight="Medium"/>
    </Border>

    <!-- ── Input row ── -->
    <Border Grid.Row="3" Background="White"
            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
      <Grid Margin="10,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="InputBox"
                 Padding="10,7" FontSize="13"
                 BorderBrush="#CED4DA" BorderThickness="1"
                 TextWrapping="NoWrap"
                 VerticalContentAlignment="Center"
                 KeyDown="InputBox_KeyDown"/>
        <Button Grid.Column="1" x:Name="BtnSend"
                Content="Send ↑"
                Style="{StaticResource BtnStyle}"
                Background="#0696D7" Foreground="White"
                Padding="12,8" FontSize="13" FontWeight="Medium"
                Margin="8,0,0,0" Click="BtnSend_Click"/>
      </Grid>
    </Border>

  </Grid>
</UserControl>
