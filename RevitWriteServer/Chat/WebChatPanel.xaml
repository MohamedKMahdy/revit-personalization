<UserControl x:Class="RevitWriteServer.Chat.WebChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="340">
  <Grid>

    <!-- WebView2 — hidden until initialised -->
    <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>

    <!-- Splash shown while WebView2 initialises or server starts -->
    <StackPanel x:Name="Splash"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="24">
      <TextBlock Text="BIM Assistant"
                 FontSize="16" FontWeight="SemiBold"
                 Foreground="#0696d7"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8"/>
      <TextBlock x:Name="SplashText"
                 Text="Starting…"
                 FontSize="13" Foreground="#555"
                 TextWrapping="Wrap"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>
      <TextBlock x:Name="UrlHint"
                 Text="http://localhost:5000"
                 FontSize="11" Foreground="#999"
                 HorizontalAlignment="Center"
                 Margin="0,10,0,0"
                 Visibility="Collapsed"/>
    </StackPanel>

  </Grid>
</UserControl>
