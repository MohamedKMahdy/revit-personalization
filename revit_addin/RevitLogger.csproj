<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Revit 2025/2026/2027 all host .NET 8 — a net10 assembly will NOT load in Revit. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <AssemblyName>RevitLogger</AssemblyName>
    <RootNamespace>RevitLogger</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
    <!-- No external NuGet packages, no WPF/WinForms — uses System.Text.Json built into
         .NET 8. The add-in is headless; the BIM Assistant UI is the Python chatbot (:5000). -->

    <!-- Revit install whose API DLLs are referenced. Override to build against another
         version, e.g.  dotnet build -p:RevitVersion=2026  -->
    <RevitVersion Condition="'$(RevitVersion)' == ''">2027</RevitVersion>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit $(RevitVersion)\RevitAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit $(RevitVersion)\RevitAPIUI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
