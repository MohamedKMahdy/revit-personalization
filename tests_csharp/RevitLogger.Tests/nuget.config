<?xml version="1.0" encoding="utf-8"?>
<!-- Repo-local override: the user-level NuGet.Config restricts packageSourceMapping to a
     few patterns (Xbim/WebView2/…), which blocks the xUnit test packages. Scope a
     permissive mapping to this test project only so `dotnet test` can restore. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
