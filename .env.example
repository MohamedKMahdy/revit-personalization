# Copy this to .env and fill in your values
# (Never commit .env — it is in .gitignore)

# Required: Anthropic API key for Pattern Agent + Macro Agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude models
PATTERN_AGENT_MODEL=claude-opus-4-7
MACRO_AGENT_MODEL=claude-sonnet-4-6

# Optional: Revit Public MCP Server URL (for --execute mode)
# Leave as default if Revit 2027 is running on the same machine
REVIT_MCP_URL=http://localhost:3000

# Optional: override log / shortcut directories
# REVIT_PERSONALIZATION_LOG_DIR=C:\Users\...\AppData\Local\RevitPersonalization\logs
# REVIT_PERSONALIZATION_SHORTCUTS_DIR=C:\Users\...\AppData\Local\RevitPersonalization\shortcuts
