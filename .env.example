# Copy this to .env and fill in your values
# (Never commit .env — it is in .gitignore)

# Required: Anthropic API key for Pattern Agent + Macro Agent
ANTHROPIC_API_KEY=sk-ant-...

# ── Model / provider switch (see shared/llm.py + litellm_config.yaml) ───────────────
# Each role accepts an alias (opus | sonnet | haiku | gemini | gemini-pro) or a full model id.
# LLM_MODEL_DEFAULT is the global fallback for any role you don't set explicitly.
#   LLM_MODEL_DEFAULT=gemini   → run the WHOLE system on Gemini's free tier
PATTERN_AGENT_MODEL=claude-opus-4-8
MACRO_AGENT_MODEL=claude-sonnet-4-6
EXECUTOR_MODEL=claude-sonnet-4-6
CHATBOT_MODEL=claude-sonnet-4-6
# LLM_MODEL_DEFAULT=

# Gemini free tier (only needed when a role uses a gemini* model — routes via the LiteLLM proxy):
# GEMINI_API_KEY=...
# LITELLM_BASE_URL=http://127.0.0.1:4000

# Optional: Revit Public MCP Server URL (for --execute mode)
# Leave as default if Revit 2027 is running on the same machine
REVIT_MCP_URL=http://localhost:3000

# Optional: override log / shortcut directories
# REVIT_PERSONALIZATION_LOG_DIR=C:\Users\...\AppData\Local\RevitPersonalization\logs
# REVIT_PERSONALIZATION_SHORTCUTS_DIR=C:\Users\...\AppData\Local\RevitPersonalization\shortcuts
